# Copy this file to .env (for local dev) and fill in your values.
# .env is gitignored — never commit real secrets.

# -------------------------------------------------------------------
# Yahoo Fantasy Sports OAuth
# Get these from https://developer.yahoo.com/apps/
# Register redirect URIs exactly as:
#   http://localhost:3000/yahoo-callback
#   https://theoffensiveline.net/yahoo-callback
# -------------------------------------------------------------------

# Client ID (Consumer Key) — used in the browser to build the OAuth redirect URL
REACT_APP_YAHOO_CLIENT_ID=

# Client Secret (Consumer Secret) — server-side only (Vercel env var for proxy).
# Add YAHOO_CLIENT_ID and YAHOO_CLIENT_SECRET to Vercel project settings.
# These are NOT prefixed with REACT_APP_ and never reach the browser.
# YAHOO_CLIENT_ID=
# YAHOO_CLIENT_SECRET=

# Optional: enable per-section performance timing in the newsletter (dev only).
# Sections taking >200ms will emit a console.warn.
# REACT_APP_NEWSLETTER_PERF=1

# -------------------------------------------------------------------
# Firebase Local Emulator Suite (dev only)
# Set to 1 to point Auth + Firestore at local emulators instead of prod.
# Start the emulators first in a separate terminal: pnpm emulators
# Emulator UI: http://localhost:4000
# Data (fake accounts, league docs) persists across restarts in
# .emulator-data/ (gitignored) — delete that folder for a clean slate.
# -------------------------------------------------------------------
# REACT_APP_USE_EMULATOR=1
